# Shared monorepo env — copy to `.env` (never commit `.env`)
# Docker Compose defaults match POSTGRES_* below when using `npm run db:up`.

# PostgreSQL
DATABASE_URL=postgres://legisarc:legisarc_dev_password@localhost:5432/legisarc

# Auth — use a long random string in production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Client → API (browser + local Server Actions)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Droplet only: Next.js container → Express on Docker network (multipart uploads)
# INTERNAL_API_URL=http://api:4000

# File storage: local (dev) | spaces (DigitalOcean Spaces / S3-compatible)
STORAGE_DRIVER=local

# Required when STORAGE_DRIVER=spaces
# SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
# SPACES_REGION=sgp1
# SPACES_BUCKET=legisarc-files
# SPACES_KEY=
# SPACES_SECRET=
# Prefer CDN URL; otherwise set SPACES_PUBLIC_URL
# SPACES_CDN_URL=https://legisarc-files.sgp1.cdn.digitaloceanspaces.com
# SPACES_PUBLIC_URL=https://legisarc-files.sgp1.digitaloceanspaces.com
# New uploads: public-read (required for browser PDF/image view). Use "none" only with a public bucket policy.
# SPACES_OBJECT_ACL=public-read
