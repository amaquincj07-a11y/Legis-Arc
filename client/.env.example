# Client env — copy to `client/.env.local` (never commit `.env.local`)
# JWT_SECRET must match the value in the repo-root `.env`.

NEXT_PUBLIC_API_URL=http://localhost:4000
# Public site origin for SEO canonical URLs, sitemap, and Open Graph
NEXT_PUBLIC_SITE_URL=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_secret
