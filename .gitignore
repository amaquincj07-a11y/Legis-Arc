# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/client/node_modules
/server/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/client/coverage
/server/coverage

# next.js
/.next/
/out/
/client/.next/
/client/out/

# production
/build
/client/build
/server/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets
.env
.env.*
.env.local
.env.*.local
!.env.example
!client/.env.example
!server/.env.example

# Uploaded PDFs / images (local disk storage)
/server/uploads/**
!/server/uploads/.gitkeep

# OS / editor
Thumbs.db
Desktop.ini

# vercel
.vercel
/client/.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/client/next-env.d.ts
/server/**/*.tsbuildinfo
